# ==============================================================================
# Cromatic Vision Optical - Backend Configuration (Go / Docker Setup)
# ==============================================================================

# Application Config
APP_NAME="cromatic-vision-api"
APP_ENV="development" # development, production, test
APP_PORT="3000"

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# PostgreSQL Config
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
POSTGRES_USER="cromatic_user"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_DB="cromatic_vision_db"

# PostgreSQL Connection Pool Tuning (optional, sensible defaults applied)
# POSTGRES_MAX_CONNS="25"
# POSTGRES_MIN_CONNS="5"

# Redis Config
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Security Config (REQUIRED in production - minimum 32 characters)
JWT_SECRET="CHANGE_ME_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Storage Config (S3/Cloudflare R2 compatible)
STORAGE_PROVIDER="mock" # mock or s3
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL_PREFIX=""

# Razorpay Payment Integration Config
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# SMTP and Notifications Service Config
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
ADMIN_EMAIL=""



